          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto coincide con el comportamiento del TUI: la transcripcion retrocede, el prompt vuelve al compositor y los cambios de archivos posteriores a ese punto se revierten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
